# ---------------------------------------------------------------------------
# Lakshya Voice Complaint System - Environment Variables
# ---------------------------------------------------------------------------

# Twilio (required for phone calls)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Groq (optional - used as primary LLM when internet available)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local LLM - used when offline or as fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Service URLs (change for Docker)
STT_SERVICE_URL=http://localhost:8001
CLASSIFIER_SERVICE_URL=http://localhost:8002
BACKEND_SERVICE_URL=http://localhost:8000
GENAI_SERVICE_URL=http://localhost:8004

# Backend auth (service account for ticket creation)
SERVICE_ACCOUNT_EMAIL=system@lakshya.ai
SERVICE_ACCOUNT_PASSWORD=Changeme123

# TTS Configuration
TTS_VOICE=en-IN
PRIMARY_TTS=auto

# LLM Configuration
PRIMARY_LLM=auto

# Network mode: "auto" (detect), "online" (prefer cloud), "offline" (local only)
NETWORK_MODE=auto

# Public host for Twilio webhook (change to your server domain)
PUBLIC_HOST=localhost:8003

# Session
SESSION_TIMEOUT_SECONDS=300
MAX_TURNS=4